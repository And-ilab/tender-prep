# Скопируйте в .env или задайте в shell (не коммитьте ключ!)
# Путь к JSON сервисного аккаунта Google (см. docs/GOOGLE_DRIVE.md)
GOOGLE_DRIVE_CREDENTIALS=./secrets/lena-drive-sa.json

# Опционально: год по умолчанию для путей _lena/tenders/<ГГГГ>/… (если не задан — текущий календарный год)
# LENA_DEFAULT_TENDER_YEAR=2026

# Опционально: дополнительные папки с контекстом (URL или id через запятую или с новой строки).
# Каждая папка — расшарить на client_email сервисного аккаунта. Файлы из корня папки попадают в context-list и agent-bundle.
# LENA_EXTRA_CONTEXT_FOLDERS=https://drive.google.com/drive/folders/XXXX,https://drive.google.com/drive/folders/YYYY
