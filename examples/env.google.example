GOOGLE_DRIVE_CREDENTIALS=./secrets/lena-drive-sa.json

# Опционально: год по умолчанию для путей _lena/tenders/<ГГГГ>/… (если не задан — текущий календарный год)
# LENA_DEFAULT_TENDER_YEAR=2026
