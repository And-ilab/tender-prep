# Не коммитить. Скопируйте в .env или задайте в shell.

# Токен от @BotFather (обязательно для любого бота)
TELEGRAM_BOT_TOKEN=123456789:ABC...

# Бот «Лена» (src/telegram/lena-bot.mjs): корень Drive — id или URL папки
LENA_DRIVE_ROOT=https://drive.google.com/drive/folders/...

# JSON ключ сервисного аккаунта (путь к файлу) — если НЕ используете OAuth ниже
# GOOGLE_DRIVE_CREDENTIALS=C:\Users\bkp2.LAPTOP-714KMOB9\Downloads\tender-prep-drive-637351043f8c.json

# --- Личный Google (OAuth): вместо SA, без Shared drive (см. docs/GOOGLE_DRIVE_OAUTH.md) ---
# GOOGLE_DRIVE_OAUTH_CLIENT=C:\secrets\google-oauth-client.json
# GOOGLE_DRIVE_OAUTH_TOKEN=C:\secrets\lena-drive-user-token.json
# Один раз: node src/cli.js drive oauth-login

# Опционально: только эти чаты (id через запятую). Узнать id группы: @userinfobot или лог бота.
# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

# Опционально: год для /bundle (по умолчанию LENA_DEFAULT_TENDER_YEAR или текущий год)
# LENA_DEFAULT_TENDER_YEAR=2026

# Опционально: дополнительные папки контекста на Drive (см. docs/GOOGLE_DRIVE.md)
# LENA_EXTRA_CONTEXT_FOLDERS=https://drive.google.com/drive/folders/...,https://...

# --- LLM (/ask, /tenderask): OpenAI-compatible Chat Completions ---
# OPENAI_API_KEY=sk-...
# или отдельный ключ только для Лены:
# LENA_OPENAI_API_KEY=sk-...
# LENA_OPENAI_BASE_URL=https://api.openai.com/v1
# LENA_OPENAI_MODEL=gpt-4o-mini
# Пример чата через DeepSeek (OpenAI-compatible):
# LENA_OPENAI_BASE_URL=https://api.deepseek.com/v1
# LENA_OPENAI_MODEL=deepseek-chat
# LENA_TELEGRAM_GROUP_ASK_REQUIRE_REPLY=1   # в группе: /ask только как «Ответить» на сообщение (см. docs/TELEGRAM.md)

# --- IceTrade bootstrap (ссылка в чате или node src/cli.js tenders icetrade-bootstrap …) ---
# LENA_ICETRADE_BOOT_MAX_FILES=30
# LENA_ICETRADE_FETCH_TIMEOUT_MS=25000
# Вложения подгружаются JS: включить Chromium (npm install playwright && npx playwright install chromium)
# LENA_ICETRADE_PLAYWRIGHT=1
# Если «Аукционные документы» на карточке всегда раскрыты — не кликать по вкладкам (быстрее)
# LENA_ICETRADE_PLAYWRIGHT_SKIP_DOC_UI_CLICKS=1
# LENA_ICETRADE_PLAYWRIGHT_STORAGE=C:\secrets\icetrade-storage.json
# LENA_ICETRADE_PLAYWRIGHT_SETTLE_MS=6000
# LENA_ICETRADE_PLAYWRIGHT_MAX_RESPONSE_BYTES=4000000
# Сессия: npm run icetrade:playwright-auth -- C:\secrets\icetrade-storage.json
# Стабильность скачивания: пауза между файлами (мс), повтор при обрыве, cookie из браузера (если нужно)
# LENA_ICETRADE_DOWNLOAD_GAP_MS=350
# LENA_ICETRADE_DOWNLOAD_RETRIES=3
# LENA_ICETRADE_DOWNLOAD_RETRY_GAP_MS=700
# LENA_ICETRADE_COOKIE=name=value; name2=value2
# Python fetch_card.py: always | auto (только если Node не дал кандидатов) | выкл.
# LENA_ICETRADE_PYTHON_FETCH=auto
# LENA_ICETRADE_PYTHON=python

# LENA_LLM_SYSTEM_PROMPT=…  # см. docs/LENA_RULES.md — раздел «Краткий системный блок»

# --- Локальный RAG (node src/cli.js rag index|query|ask) ---
# Индекс использует POST …/embeddings. У DeepSeek обычно нет этого endpoint — задайте отдельный хост эмбеддингов:
# LENA_EMBEDDING_BASE_URL=https://…/v1
# LENA_EMBEDDING_API_KEY=sk-…   # если не тот же, что LENA_OPENAI_API_KEY
# LENA_EMBEDDING_MODEL=text-embedding-3-small
# LENA_EMBEDDING_DIMENSIONS=1536
# Локальные эмбеддинги на CPU (см. scripts/local_openai_embeddings/README.md):
# set LENA_EMBEDDING_BASE_URL=http://127.0.0.1:8765/v1
# set LENA_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Опционально: архив тендеров (RAG) в Telegram — /archivesearch, /archiveask
# LENA_RAG_INDEX_DIR=C:\data\rag-index-2025-drive
# LENA_RAG_TOP_K=8
