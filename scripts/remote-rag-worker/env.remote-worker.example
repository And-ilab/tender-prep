# Скопируйте в env.remote-worker.local (не коммитить) на удалённой машине.
# PowerShell: Get-Content env.remote-worker.local | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim(), 'Machine') } }

# --- Пути на удалённой машине ---
TENDER_PREP_ROOT=C:\tender-prep
TENDER_DATA_ROOT=C:\data

# --- Сервер эмбеддингов (Python) ---
LOCAL_EMBEDDINGS_HOST=0.0.0.0
LOCAL_EMBEDDINGS_PORT=8765
LOCAL_EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Обязательно задайте длинный секрет, если слушаете не только localhost:
LOCAL_EMBEDDINGS_API_KEY=change-me-to-long-random-secret

# --- Node rag index|query|ask (клиент к своему или удалённому embeddings) ---
LENA_EMBEDDING_BASE_URL=http://127.0.0.1:8765/v1
LENA_EMBEDDING_API_KEY=change-me-to-long-random-secret
LENA_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# С ноутбука укажите IP удалённой машины вместо 127.0.0.1:
# LENA_EMBEDDING_BASE_URL=http://192.168.1.50:8765/v1

# --- Google Drive (если corpus-pull на удалённой машине) ---
# GOOGLE_DRIVE_CREDENTIALS=C:\secrets\tender-prep-drive.json

# Архив 2025 на Drive:
# DRIVE_ARCHIVE_2025=https://drive.google.com/drive/folders/1VGgxftxNdwdF1vDvz45vSy4EzpWwqnK_
