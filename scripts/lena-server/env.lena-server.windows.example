# Скопируйте в C:\tender-prep\.env (не коммитить).
# Пути — Windows Server. Секреты удобно держать в C:\secrets\tender-prep\

# --- Обязательно ---
TELEGRAM_BOT_TOKEN=
LENA_DRIVE_ROOT=https://drive.google.com/drive/folders/...

GOOGLE_DRIVE_CREDENTIALS=C:\secrets\tender-prep\drive-service-account.json
# OAuth (личный Gmail вместо SA):
# GOOGLE_DRIVE_OAUTH_CLIENT=C:\secrets\tender-prep\oauth-client.json
# GOOGLE_DRIVE_OAUTH_TOKEN=C:\secrets\tender-prep\drive-user-token.json

# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

# --- LLM ---
OPENAI_API_KEY=
# LENA_OPENAI_BASE_URL=https://api.openai.com/v1
# LENA_OPENAI_MODEL=gpt-4o-mini

# --- IceTrade ---
LENA_ICETRADE_PLAYWRIGHT=1
LENA_ICETRADE_PLAYWRIGHT_STORAGE=C:\secrets\tender-prep\icetrade-storage.json
LENA_ICETRADE_PLAYWRIGHT_DOWNLOADS_DIR=C:\data\playwright-downloads
# Chromium для службы Windows (SYSTEM): общий каталог, см. install-windows.ps1
LENA_PLAYWRIGHT_BROWSERS_PATH=C:\ProgramData\ms-playwright
# LENA_ICETRADE_COOKIE=
# LENA_TELEGRAM_ICETRADE_IMPORT_ONLY=1

# --- OCR / Python PDF ---
LENA_PYTHON=C:\tender-prep\.venv\Scripts\python.exe
# LENA_OCR_TESSERACT=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- RAG (на этом же сервере) ---
# LENA_RAG_INDEX_DIR=C:\data\rag-index-2025-drive
# LENA_EMBEDDING_BASE_URL=http://127.0.0.1:8765/v1
# LENA_EMBEDDING_API_KEY=change-me-to-long-random-secret
# LENA_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# LENA_TELEGRAM_DEBUG=1
# LENA_TELEGRAM_GROUP_ASK_REQUIRE_REPLY=1
