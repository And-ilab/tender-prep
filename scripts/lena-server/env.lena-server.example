# Скопируйте в корень репозитория как .env (не коммитить).
# Linux-пути ниже — замените на свои. Windows: C:\tender-prep, C:\secrets\…

# --- Обязательно ---
TELEGRAM_BOT_TOKEN=
LENA_DRIVE_ROOT=https://drive.google.com/drive/folders/...

# Сервисный аккаунт (рекомендуется на сервере):
GOOGLE_DRIVE_CREDENTIALS=/etc/tender-prep/secrets/drive-service-account.json
# Или OAuth (личный Gmail):
# GOOGLE_DRIVE_OAUTH_CLIENT=/etc/tender-prep/secrets/oauth-client.json
# GOOGLE_DRIVE_OAUTH_TOKEN=/etc/tender-prep/secrets/drive-user-token.json

# Whitelist чатов в проде (id через запятую):
# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

# --- LLM ---
OPENAI_API_KEY=
# LENA_OPENAI_BASE_URL=https://api.openai.com/v1
# LENA_OPENAI_MODEL=gpt-4o-mini

# --- IceTrade (headless сервер) ---
LENA_ICETRADE_PLAYWRIGHT=1
LENA_ICETRADE_PLAYWRIGHT_STORAGE=/etc/tender-prep/secrets/icetrade-storage.json
LENA_ICETRADE_PLAYWRIGHT_DOWNLOADS_DIR=/data/playwright-downloads
# LENA_ICETRADE_COOKIE=
# LENA_TELEGRAM_ICETRADE_IMPORT_ONLY=1

# --- OCR / Python PDF ---
LENA_PYTHON=/opt/tender-prep/.venv/bin/python
# LENA_OCR_TESSERACT=tesseract

# --- RAG (индекс и embeddings на этом же сервере) ---
# LENA_RAG_INDEX_DIR=/data/rag-index-2025-drive
# LENA_EMBEDDING_BASE_URL=http://127.0.0.1:8765/v1
# LENA_EMBEDDING_API_KEY=change-me-to-long-random-secret
# LENA_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Прочее ---
# LENA_TELEGRAM_DEBUG=1
# LENA_TELEGRAM_GROUP_ASK_REQUIRE_REPLY=1
